<!DOCTYPE html>
<html>
<head>

<title>Database - <%= tableName %></title>

<style>

body{
background:#0b0b0b;
color:white;
font-family:monospace;
margin:0;
padding:0;
}

.container{
width:100%;
height:100vh;
padding:20px;
box-sizing:border-box;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

button{
padding:10px 16px;
background:#00ff99;
border:none;
cursor:pointer;
font-weight:bold;
}

button:hover{
background:#00ffaa;
}

.table-container{
width:100%;
height:85vh;
overflow:auto;
border:1px solid #333;
}

table{
border-collapse:collapse;
width:100%;
min-width:1000px;
}

th, td{
border:1px solid #333;
padding:6px;
text-align:left;
}

th{
background:#111;
color:#00ffcc;
position:sticky;
top:0;
}

tr:nth-child(even){
background:#111;
}

</style>

</head>

<body>

<div class="container">

<div class="header">

<h2>Database: <%= tableName %></h2>

<a href="/level/<%= level %>">
<button>Back</button>
</a>

</div>

<div class="table-container">

<table>

<thead>
<tr>
<% Object.keys(rows[0]).forEach(col => { %>
<th><%= col %></th>
<% }) %>
</tr>
</thead>

<tbody>

<% rows.forEach(row => { %>

<tr>
<% Object.values(row).forEach(val => { %>
<td><%= val %></td>
<% }) %>
</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</body>
</html>